@using System.Text.Json
@using FWO.Ui.Services

@inject ApiConnection apiConnection
@inject UserConfig userConfig

<PopUp Title="@(userConfig.GetText("edit_action"))" Show="@EditActionMode" Size=PopupSize.Large OnClose="CancelActionPopup">
    <Body>
        @if (EditActionMode)
        {
            <h5 class="mt-1">@(userConfig.GetText("general"))</h5>
            <EditActionGeneral ActAction="actAction" AvailableTaskTypes="AvailableTaskTypes" ActionTypeChanged="ActionTypeChanged" />
            <hr />
            <h5 class="mt-1">@(userConfig.GetText("action_specific"))</h5>
            <div class="form-group row col-sm-12 mt-2">
                @switch (actAction.ActionType)
                {
                    case nameof(StateActionTypes.AutoPromote):
                        <EditActionAutoPromote ActAction="actAction" States="States" Policies="Policies" />
                        break;
                    case nameof(StateActionTypes.AddApproval):
                        <EditActionAddApproval ActAction="actAction" States="States" UserAndGroupList="UserAndGroupList" />
                        break;
                    case nameof(StateActionTypes.SetAlert):
                        <div class="col-sm-12">
                            <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5524"))">
                                <label class="col-sm-2 col-form-label col-form-label-sm">@(userConfig.GetText("message_text")):</label>
                                <input type="text" class="col-sm-10" @bind="message" />
                            </div>
                        </div>
                        break;
                    case nameof(StateActionTypes.TrafficPathAnalysis):
                        <div class="col-sm-4">
                            <div class="form-group row" data-toggle="tooltip" title="@(userConfig.PureLine("H5526"))">
                                <label class="col-sm-4 col-form-label col-form-label-sm">@(userConfig.GetText("option")):</label>
                                <div class="col-sm-8">
                                    <Dropdown ElementType="PathAnalysisOptions" @bind-SelectedElement="actPathAnalysisParams.Option"
                                            ElementToString="@(o => userConfig.GetText(o.ToString()))"
                                            Elements="Enum.GetValues(typeof(PathAnalysisOptions)).Cast<PathAnalysisOptions>()">
                                        <ElementTemplate Context="opt">
                                            @(userConfig.GetText(opt.ToString()))
                                        </ElementTemplate>
                                    </Dropdown>
                                </div>
                            </div>
                        </div>
                        break;
                    case nameof(StateActionTypes.SendEmail):
                        <EditActionSendEmail @ref="sendEmailEditor" ActAction="actAction" PersistedAction="persistedAction" />
                        break;
                    case nameof(StateActionTypes.UpdateModelling):
                        <EditActionUpdateModelling ActAction="actAction" AvailableModIntegrationStateNames="AvailableModIntegrationStateNames" />
                        break;
                    case nameof(StateActionTypes.CreateFlow):
                        <EditActionCreateFlow ActAction="actAction" States="States" />
                        break;
                    case nameof(StateActionTypes.BundleTasks):
                        <EditActionBundleTasks ActAction="actAction" Policies="Policies" />
                        break;
                    default:
                        break;
                }
            </div>
            <hr />
            <EditActionUsingStates @ref="usingStatesEditor"
                                   ActAction="actAction"
                                   States="States" />
        }
    </Body>
    <Footer>
        <div class="btn-group">
            <ExecutionModeAuthorizeView Roles="@($"{Roles.Admin}, {Roles.FwAdmin}")">
                <Authorized>
                    <button type="button" class="btn btn-sm btn-primary" @onclick="SaveAction">@(DisplayService.DisplayButton(userConfig, "save", Icons.Save))</button>
                </Authorized>
                <NotAuthorized>
                    <button type="button" class="btn btn-sm btn-primary" disabled>@(DisplayService.DisplayButton(userConfig, "save", Icons.Save))</button>
                </NotAuthorized> 
            </ExecutionModeAuthorizeView>
            <button type="button" class="btn btn-sm btn-secondary" @onclick="Cancel">@(DisplayService.DisplayButton(userConfig, "cancel", Icons.Cancel))</button>
        </div>
    </Footer>
</PopUp>

@code {
    [CascadingParameter]
    Action<Exception?, string, string, bool> DisplayMessageInUi { get; set; } = DefaultInit.DoNothing;

    [Parameter]
    public List<WfStateAction> Actions { get; set; } = [];

    [Parameter]
    public List<WfState> States { get; set; } = [];

    [Parameter]
    public List<CompliancePolicy> Policies { get; set; } = [];

    [Parameter]
    public List<UiUser> UserAndGroupList { get; set; } = [];

    [Parameter]
    public List<WfTaskType> AvailableTaskTypes { get; set; } = [];

    [Parameter]
    public List<string> AvailableModIntegrationStateNames { get; set; } = [];

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private WfStateAction actAction = new();
    private WfStateAction persistedAction = new();
    private string message = "";
    private PathAnalysisActionParams actPathAnalysisParams = new();
    private EditActionSendEmail? sendEmailEditor;
    private EditActionUsingStates? usingStatesEditor;
    private bool EditActionMode;
    private bool AddActionMode;

    public async Task OpenAddAsync()
    {
        await InvokeAsync(() =>
        {
            AddActionMode = true;
            EditAction(new WfStateAction());
            StateHasChanged();
        });
    }

    public async Task OpenEditAsync(WfStateAction action)
    {
        await InvokeAsync(() =>
        {
            AddActionMode = false;
            EditAction(action);
            StateHasChanged();
        });
    }

    private void EditAction(WfStateAction action)
    {
        actAction = action;
        persistedAction = new WfStateAction(action);
        ResetActionEditState();
        LoadActionExternalParams(action);
        EditActionMode = true;
    }

    private void ResetActionEditState()
    {
        ResetActionSpecificEditState();
    }

    private void ResetActionSpecificEditState()
    {
        actPathAnalysisParams = new();
        message = "";
    }

    private void ActionTypeChanged(string? actionType)
    {
        string newActionType = actionType ?? "";
        string previousActionType = actAction.ActionType;
        if (previousActionType == newActionType)
        {
            return;
        }

        actAction.ActionType = newActionType;
        actAction.ExternalParams = "";
        ResetActionSpecificEditState();
    }

    private void LoadActionExternalParams(WfStateAction action)
    {
        if (string.IsNullOrWhiteSpace(action.ExternalParams) || action.ExternalParams == "{}")
        {
            return;
        }

        switch(action.ActionType)
        {
            case nameof(StateActionTypes.SetAlert):
                message = actAction.ExternalParams;
                break;
            case nameof(StateActionTypes.TrafficPathAnalysis):
                actPathAnalysisParams = JsonSerializer.Deserialize<PathAnalysisActionParams>(action.ExternalParams) ?? throw new JsonException("Extparams could not be parsed.");
                break;
            default:
                break;
        }
    }

    private async Task SaveAction()
    {
        try
        {
            if (!await TryUpdateExternalParams())
            {
                return;
            }

            if(AddActionMode)
            {
                await SaveNewAction();
            }
            else
            {
                await SaveExistingAction();
            }
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("save_action"), "", true);
        }
    }

    private async Task<bool> TryUpdateExternalParams()
    {
        switch(actAction.ActionType)
        {
            case nameof(StateActionTypes.SetAlert):
                actAction.ExternalParams = message;
                return true;
            case nameof(StateActionTypes.TrafficPathAnalysis):
                actAction.ExternalParams = JsonSerializer.Serialize(actPathAnalysisParams);
                return true;
            case nameof(StateActionTypes.SendEmail):
                return sendEmailEditor != null && await sendEmailEditor.PrepareForSaveAsync();
            default:
                return true;
        }
    }

    private async Task SaveNewAction()
    {
        var Variables = new
        {
            name = actAction.Name,
            actionType = actAction.ActionType,
            scope = actAction.Scope,
            taskType = actAction.TaskType,
            phase = actAction.Phase,
            eventt = actAction.Event,
            buttonText = actAction.ButtonText,
            externalParameters = actAction.ExternalParams
        };
        ReturnId[]? returnIds = (await apiConnection.SendQueryAsync<ReturnIdWrapper>(RequestQueries.newAction, Variables)).ReturnIds;
        if (returnIds == null)
        {
            DisplayMessageInUi(null, userConfig.GetText("save_action"), userConfig.GetText("E8011"), true);
            return;
        }

        actAction.Id = returnIds[0].NewId;
        if (usingStatesEditor != null)
        {
            await usingStatesEditor.PersistPendingStateLinksAsync();
        }
        Actions.Add(actAction);
        EditActionMode = false;
        AddActionMode = false;
        await NotifyChanged();
    }

    private async Task SaveExistingAction()
    {
        int updatedId = await UpdateAction(actAction, actAction.ExternalParams);
        if(updatedId != actAction.Id)
        {
            DisplayMessageInUi(null, userConfig.GetText("save_action"), userConfig.GetText("E8011"), true);
            return;
        }

        if (usingStatesEditor != null)
        {
            await usingStatesEditor.PersistPendingStateLinksAsync();
        }
        Actions[Actions.FindIndex(x => x.Id == actAction.Id)] = actAction;
        EditActionMode = false;
        await NotifyChanged();
    }

    private void CancelActionPopup()
    {
        _ = Cancel();
    }

    private async Task Cancel()
    {
        try
        {
            if (AddActionMode && sendEmailEditor != null)
            {
                await sendEmailEditor.CleanupOnCancelAsync();
            }
            usingStatesEditor?.ResetPendingStateLinks();
        }
        catch (Exception exception)
        {
            DisplayMessageInUi(exception, userConfig.GetText("delete_notification"), "", true);
        }
        EditActionMode = false;
        AddActionMode = false;
    }

    private async Task<int> UpdateAction(WfStateAction action, string externalParams)
    {
        var Variables = new
        {
            id = action.Id,
            name = action.Name,
            actionType = action.ActionType,
            scope = action.Scope,
            taskType = action.TaskType,
            phase = action.Phase,
            eventt = action.Event,
            buttonText = action.ButtonText,
            externalParameters = externalParams
        };
        return (await apiConnection.SendQueryAsync<ReturnId>(RequestQueries.updateAction, Variables)).UpdatedId;
    }

    private Task NotifyChanged() => OnChanged.HasDelegate ? OnChanged.InvokeAsync() : Task.CompletedTask;
}
